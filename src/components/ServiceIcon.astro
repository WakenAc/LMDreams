---
import type { ServiceEntry } from '@/types/content';

interface Props {
  icon: ServiceEntry['icon'];
}

const { icon } = Astro.props;
---

{
  icon === 'build' && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class="service-icon-svg">
      <path d="M3 19h18v2H3zm2-2h3V9h8v8h3L12 3z" />
    </svg>
  )
}
{
  icon === 'tools' && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class="service-icon-svg">
      <path d="m22 19.59-6.29-6.3a7 7 0 0 1-8.89-8.9l3.18 3.18L12.18 5l-3.2-3.18a7 7 0 0 1 8.9 8.88L24 17.18zM5 12l2 2-5 5-2-2z" />
    </svg>
  )
}
{
  icon === 'finish' && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class="service-icon-svg">
      <path d="M3 17h18v2H3zm2-4h14v2H5zm3-4h8v2H8zm2-4h4v2h-4z" />
    </svg>
  )
}
{
  icon === 'repair' && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class="service-icon-svg">
      <path d="M22.7 19.3 13 9.6a5 5 0 0 1-6.3-6.3L10 6.6 12.6 4 9.3.7A5 5 0 0 1 15.6 7L25.3 16.7zM2 22l4-4 2 2-4 4z" />
    </svg>
  )
}
{
  icon === 'coordination' && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class="service-icon-svg">
      <path d="M10 3h4v4h-4zm-7 7h4v4H3zm14 0h4v4h-4zm-7 7h4v4h-4zM8 5H6a3 3 0 0 0-3 3v2h2V8a1 1 0 0 1 1-1h2zm8 0h2a3 3 0 0 1 3 3v2h-2V8a1 1 0 0 0-1-1h-2zm2 11h2v2a3 3 0 0 1-3 3h-2v-2h2a1 1 0 0 0 1-1zm-12 3H4a3 3 0 0 1-3-3v-2h2v2a1 1 0 0 0 1 1h2z" />
    </svg>
  )
}
{
  icon === 'supervision' && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class="service-icon-svg">
      <path d="M12 3 1 9l11 6 9-4.91V17h2V9zM5 13.18V17l7 4 7-4v-3.82l-7 3.82z" />
    </svg>
  )
}
