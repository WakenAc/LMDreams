{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 3
    },
    "slug": {
      "type": "string",
      "minLength": 3
    },
    "summary": {
      "type": "string",
      "minLength": 10
    },
    "description": {
      "type": "string",
      "minLength": 30
    },
    "benefits": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 5
      }
    },
    "image": {
      "type": "string"
    },
    "imageAlt": {
      "type": "string"
    },
    "displayOrder": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "published": {
      "type": "boolean"
    },
    "isExample": {
      "type": "boolean"
    },
    "ctaLabel": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "slug",
    "summary",
    "description",
    "benefits",
    "displayOrder",
    "published"
  ]
}